# --- RCON (enable in server.properties: enable-rcon=true, rcon.password=..., rcon.port=25575) ---
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me
POLL_INTERVAL=1.0

# --- LLM via your LiteLLM gateway (OpenAI-compatible) ---
LLM_BASE_URL=http://localhost:4000
LLM_API_KEY=sk-local
LLM_MODEL=qwen-local
LLM_TEMPERATURE=0.85

# --- Optional tracing ---
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=...
# LANGFUSE_SECRET_KEY=...
# LANGFUSE_HOST=http://localhost:3000

# --- Safety policy (override defaults if you like) ---
# BLESS_EFFECTS=regeneration,absorption,strength,resistance,speed
# CURSE_EFFECTS=weakness,slowness,poison,blindness,wither
# THREAT_MOBS=zombie,husk,skeleton,creeper,sulfur_cube
MAX_AMPLIFIER=4
MAX_DURATION_S=120
MAX_THREAT_COUNT=6
COEFF_MAX=80

# --- Demands (proactive) ---
DEMAND_MEAN_MINUTES=60
DEMAND_COOLDOWN_MINUTES=15
DEMAND_MIN_PLAYERS=2
DEMAND_DEADLINE_MIN=3
DEMAND_DEADLINE_MAX=30
DEMAND_THRESHOLD_MAX=2000
DEMAND_OVERTIME_S=45
# DEMAND_CRITERIA=minecraft.mined:minecraft.diamond_ore,minecraft.killed:minecraft.zombie,...

# --- Memory ---
STATE_DIR=state
CHRONICLE_EVERY=4
