# --- RCON (enable in server.properties: enable-rcon=true, rcon.password=..., rcon.port=25575) ---
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me
POLL_INTERVAL=1.0

# --- LLM via your LiteLLM gateway (OpenAI-compatible) ---
LLM_BASE_URL=http://localhost:4000
LLM_API_KEY=sk-local
LLM_MODEL=qwen-local
LLM_TEMPERATURE=0.85

# --- Optional tracing ---
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=...
# LANGFUSE_SECRET_KEY=...
# LANGFUSE_HOST=http://localhost:3000

# --- Safety policy (override defaults if you like) ---
# BLESS_EFFECTS=regeneration,absorption,strength,resistance,speed
# CURSE_EFFECTS=weakness,slowness,poison,blindness,wither
# THREAT_MOBS=zombie,husk,skeleton,creeper,sulfur_cube
MAX_AMPLIFIER=4
MAX_DURATION_S=120
MAX_THREAT_COUNT=6
COEFF_MAX=80

# --- Demands (proactive) ---
DEMAND_MEAN_MINUTES=60
DEMAND_COOLDOWN_MINUTES=15
DEMAND_MIN_PLAYERS=2
DEMAND_DEADLINE_MIN=3
DEMAND_DEADLINE_MAX=30
DEMAND_THRESHOLD_MAX=2000
DEMAND_OVERTIME_S=45
# DEMAND_CRITERIA=minecraft.mined:minecraft.diamond_ore,minecraft.killed:minecraft.zombie,...

# --- Wrath (shared, visible disposition; falls on appeasement, decays when idle) ---
WRATH_MAX=5
# Per-level mob buffs as fractions (index = wrath level 0..WRATH_MAX, add_multiplied_base).
WRATH_MOB_DMG=0.0,0.1,0.2,0.35,0.5,0.75
WRATH_MOB_HP=0.0,0.0,0.15,0.25,0.4,0.6
WRATH_BUFF_RADIUS=48
WRATH_DECAY_MINUTES=25
WRATH_ON_FAIL=1
WRATH_ON_SUCCESS=1

# --- World events (temporary flavour channel) ---
WORLD_EVENTS=spawn_surge,storm,nightfall,dread,blood_moon
EVENT_MAX_DURATION_S=300
EVENT_SPAWN_CAP=12
SURGE_MOBS=zombie,husk,skeleton,spider,creeper,phantom,pillager
# MASS_EFFECTS=regeneration,strength,weakness,slowness,poison,blindness,darkness,...

# --- External-datapack rituals: friendly-name=function-id pairs (empty = none) ---
# EXTERNAL_RITUALS=plague=mypack:plague,boon=mypack:bless_all

# --- Communal favor pool (shared ledger the group fills with tribute) ---
FAVOR_POOL_MAX=1000
FAVOR_SPEND_COST=150
FAVOR_BOON_DURATION=40
FAVOR_BOONS=mercy,feast,reprieve,calm

# --- Foreshadowing (speak an omen now, deliver a deferred action later) ---
FORESHADOW_MIN_S=10
FORESHADOW_MAX_S=1800

# --- Memory ---
STATE_DIR=state
CHRONICLE_EVERY=4
